//@version=5
indicator("Auto Pivot Support & Resistance", overlay=true, max_lines_count=50)

leftLen = 15
rightLen = 15

ph = ta.pivothigh(high, leftLen, rightLen)
pl = ta.pivotlow(low, leftLen, rightLen)

if not na(ph)
    line.new(bar_index[rightLen], ph, bar_index, ph, color=color.red, width=2, extend=extend.right, style=line.style_solid)

if not na(pl)
    line.new(bar_index[rightLen], pl, bar_index, pl, color=color.green, width=2, extend=extend.right, style=line.style_solid)

// Add some basic moving averages for context
plot(ta.sma(close, 50), color=color.blue, title="SMA 50")